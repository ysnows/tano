{
  "name": "llm_ios",
  "version": "1.0.0",
  "title": "iOS LLM Providers",
  "description": "Lightweight LLM providers for iOS using native https.request",
  "icon": "icon.png",
  "author": "enconvo",
  "minAppVersion": "1.0.0",
  "categories": ["Provider"],
  "commands": [
    {
      "name": "chat_openai",
      "title": "OpenAI (iOS)",
      "description": "OpenAI-compatible chat (GPT-4, etc.)",
      "commandType": "provider",
      "mode": "no-view",
      "preferences": [
        {
          "name": "api_key",
          "title": "API Key",
          "type": "password",
          "required": true
        },
        {
          "name": "base_url",
          "title": "Base URL",
          "type": "textfield",
          "default": "https://api.openai.com"
        },
        {
          "name": "model",
          "title": "Model",
          "type": "textfield",
          "default": "gpt-4o-mini"
        }
      ]
    },
    {
      "name": "chat_groq",
      "title": "Groq (iOS)",
      "description": "Groq cloud LLM (fast inference)",
      "commandType": "provider",
      "mode": "no-view",
      "preferences": [
        {
          "name": "api_key",
          "title": "API Key",
          "type": "password",
          "required": true
        },
        {
          "name": "model",
          "title": "Model",
          "type": "textfield",
          "default": "llama-3.3-70b-versatile"
        }
      ]
    },
    {
      "name": "chat_anthropic",
      "title": "Anthropic (iOS)",
      "description": "Claude models via Anthropic API",
      "commandType": "provider",
      "mode": "no-view",
      "preferences": [
        {
          "name": "api_key",
          "title": "API Key",
          "type": "password",
          "required": true
        },
        {
          "name": "model",
          "title": "Model",
          "type": "textfield",
          "default": "claude-sonnet-4-6"
        }
      ]
    },
    {
      "name": "chat",
      "title": "iOS Chat",
      "description": "Chat using configured iOS LLM provider",
      "commandType": "chat",
      "mode": "no-view",
      "preferences": [
        {
          "name": "api_key",
          "title": "API Key",
          "type": "password",
          "required": true
        },
        {
          "name": "provider",
          "title": "Provider",
          "type": "dropdown",
          "default": "groq",
          "data": [
            {"title": "Groq", "value": "groq"},
            {"title": "OpenAI", "value": "openai"},
            {"title": "Anthropic", "value": "anthropic"}
          ]
        },
        {
          "name": "base_url",
          "title": "Base URL (OpenAI-compatible)",
          "type": "textfield",
          "default": ""
        },
        {
          "name": "model",
          "title": "Model",
          "type": "textfield",
          "default": "llama-3.3-70b-versatile"
        },
        {
          "name": "system_prompt",
          "title": "System Prompt",
          "type": "multiline_textfield",
          "default": "You are a helpful assistant."
        },
        {
          "name": "temperature",
          "title": "Temperature",
          "type": "textfield",
          "default": "0.7"
        },
        {
          "name": "max_tokens",
          "title": "Max Tokens",
          "type": "textfield",
          "default": "4096"
        }
      ]
    }
  ]
}
