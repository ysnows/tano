#!/usr/bin/env bash
set -euo pipefail

TEST_ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_ROOT="${TEST_ROOT}/tools"
CATEGORY_ROOT="${TEST_ROOT}/module-categories"
CATEGORY_GENERATOR="${TOOLS_ROOT}/generate_test_module_categories.py"
RUN_CWD=""
CATEGORY_TESTS_FILE=""
COUNTS_OUTPUT_FILE=""

cleanup() {
  if [[ -n "${CATEGORY_TESTS_FILE}" && -f "${CATEGORY_TESTS_FILE}" ]]; then
    rm -f "${CATEGORY_TESTS_FILE}"
  fi
  if [[ -n "${COUNTS_OUTPUT_FILE}" && -f "${COUNTS_OUTPUT_FILE}" ]]; then
    rm -f "${COUNTS_OUTPUT_FILE}"
  fi
}

trap cleanup EXIT

resolve_run_cwd() {
  local test_dir_basename
  test_dir_basename="$(basename -- "${TEST_ROOT}")"

  # Many core tests invoke child processes with paths like `test/fixtures/...`.
  # Run from a workspace root where `test/` resolves to this vendored suite.
  if [[ "${test_dir_basename}" == "test" ]]; then
    RUN_CWD="$(dirname -- "${TEST_ROOT}")"
    return
  fi

  local alias_root="${TEST_ROOT}/.workspace"
  mkdir -p "${alias_root}"
  ln -sfn "${TEST_ROOT}" "${alias_root}/test"
  RUN_CWD="${alias_root}"
}

resolve_runner() {
  local requested="${NODE_TEST_RUNNER:-node}"

  if [[ "${requested}" == "node" ]]; then
    if [[ -n "${NODE_TEST_NODE_BINARY:-}" && -x "${NODE_TEST_NODE_BINARY}" ]]; then
      printf '%s\n' "${NODE_TEST_NODE_BINARY}"
      return
    fi
    if [[ -x "${TEST_ROOT}/../out/Release/node" ]]; then
      printf '%s\n' "${TEST_ROOT}/../out/Release/node"
      return
    fi
    if [[ -x "${TEST_ROOT}/../out/Debug/node" ]]; then
      printf '%s\n' "${TEST_ROOT}/../out/Debug/node"
      return
    fi
    local node_in_path
    node_in_path="$(command -v node 2>/dev/null || true)"
    if [[ -n "${node_in_path}" ]]; then
      printf '%s\n' "${node_in_path}"
      return
    fi
    echo "Could not resolve a Node binary. Set NODE_TEST_RUNNER or NODE_TEST_NODE_BINARY." >&2
    exit 1
  fi

  if [[ "$(basename -- "${requested}")" == "deno" ]]; then
    printf '%s\n' "${TEST_ROOT}/tools/deno-node-runner"
    return
  fi

  if [[ "${requested}" != */* ]]; then
    local resolved
    resolved="$(command -v "${requested}" 2>/dev/null || true)"
    if [[ -n "${resolved}" ]]; then
      printf '%s\n' "${resolved}"
      return
    fi
  fi

  printf '%s\n' "${requested}"
}

refresh_category_lists() {
  python3 "${CATEGORY_GENERATOR}" >/dev/null
}

load_category_tests() {
  python3 - "${CATEGORY_ROOT}" "$@" <<'PY'
import sys
from pathlib import Path

root = Path(sys.argv[1])
requested_specs = sys.argv[2:]

if not root.is_dir():
    raise SystemExit(f"Category directory not found: {root}")

available = {}
for path in sorted(root.glob("*.txt")):
    stem = path.stem
    if stem == "other":
        category = "other"
    elif stem.startswith("node_"):
        category = f"node:{stem[len('node_'):]}"
    else:
        category = stem
    available[category] = path

requested = []
for spec in requested_specs:
    for part in spec.split(","):
        part = part.strip()
        if part:
            requested.append(part)

if not requested:
    raise SystemExit("No categories were provided.")

unknown = [category for category in requested if category not in available]
if unknown:
    print(
        "Unknown category value(s): " + ", ".join(unknown),
        file=sys.stderr,
    )
    print("Known categories:", file=sys.stderr)
    for category in sorted(available):
        print(category, file=sys.stderr)
    raise SystemExit(1)

selected = set()
count = 0
for category in requested:
    with available[category].open(encoding="utf8") as handle:
        for line in handle:
            test = line.strip()
            if not test or test in selected:
                continue
            selected.add(test)
            print(test)
            count += 1

if count == 0:
    print(
        "No runnable tests matched categories: " + ", ".join(requested),
        file=sys.stderr,
    )
    raise SystemExit(1)
PY
}

print_counts_only() {
  python3 - "$1" <<'PY'
import re
import sys
from pathlib import Path

text = Path(sys.argv[1]).read_text(encoding='utf-8', errors='replace')
text = text.replace('\r', '\n')
ansi_pattern = re.compile(r'\x1b\[[0-9;?]*[ -/]*[@-~]')
done_pattern = re.compile(r'\+\s*(\d+)\|-\s*(\d+)\]: Done\b')

for raw_line in reversed(text.splitlines()):
    line = ansi_pattern.sub('', raw_line)
    match = done_pattern.search(line)
    if match is None:
        continue
    passed = int(match.group(1))
    failed = int(match.group(2))
    total = passed + failed
    print(f'total={total} passed={passed} failed={failed}')
    raise SystemExit(0)

raise SystemExit('Could not parse test counts.')
PY
}

counts_only=0
category_specs=()
passthrough_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --counts-only)
      counts_only=1
      shift
      ;;
    --category=*)
      category_specs+=("${1#*=}")
      shift
      ;;
    --category)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --category" >&2
        exit 1
      fi
      category_specs+=("$2")
      shift 2
      ;;
    --categories=*)
      category_specs+=("${1#*=}")
      shift
      ;;
    --categories)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --categories" >&2
        exit 1
      fi
      category_specs+=("$2")
      shift 2
      ;;
    *)
      passthrough_args+=("$1")
      shift
      ;;
  esac
done

suites=()
while IFS= read -r suite; do
  suites+=("${suite}")
done < <(python3 - "${TEST_ROOT}" <<'PY'
import os
import sys
from pathlib import Path

root = Path(sys.argv[1])
excluded = {
    'cctest',
    'benchmark',
    'addons',
    'doctool',
    'embedding',
    'overlapped-checker',
    'wasi',
    'v8-updates',
    'code-cache',
    'internet',
    'tick-processor',
    'pummel',
    'wpt',
}
for value in os.environ.get('NODE_TEST_EXCLUDE_SUITES', '').split(','):
    value = value.strip()
    if value:
        excluded.add(value)

for entry in sorted(root.iterdir()):
    if not entry.is_dir():
        continue
    if entry.name in excluded:
        continue
    if (entry / 'testcfg.py').is_file():
        print(entry.name)
PY
)

if [[ ${#suites[@]} -eq 0 ]]; then
  echo "No test suites were selected."
  exit 1
fi

target_args=("${suites[@]}")
if [[ ${#category_specs[@]} -gt 0 ]]; then
  refresh_category_lists
  CATEGORY_TESTS_FILE="$(mktemp "${TEST_ROOT}/.tmp.category-tests.XXXXXX")"
  if ! load_category_tests "${category_specs[@]}" > "${CATEGORY_TESTS_FILE}"; then
    exit 1
  fi

  target_args=()
  while IFS= read -r test_selector; do
    target_args+=("${test_selector}")
  done < "${CATEGORY_TESTS_FILE}"

  if [[ ${#target_args[@]} -eq 0 ]]; then
    echo "No tests were selected from the requested categories." >&2
    exit 1
  fi
fi

runner="$(resolve_runner)"
resolve_run_cwd

unset FORCE_COLOR
unset NO_COLOR

cd "${RUN_CWD}"

command=(
  python3 "${TOOLS_ROOT}/test.py"
  --timeout 10
  --test-root "${TEST_ROOT}"
  --shell "${runner}"
  "${target_args[@]}"
)

if [[ ${#passthrough_args[@]} -gt 0 ]]; then
  command+=("${passthrough_args[@]}")
fi

if [[ ${counts_only} -eq 1 ]]; then
  COUNTS_OUTPUT_FILE="$(mktemp "${TEST_ROOT}/.tmp.counts-output.XXXXXX")"
  if "${command[@]}" > "${COUNTS_OUTPUT_FILE}" 2>&1; then
    status=0
  else
    status=$?
  fi

  print_counts_only "${COUNTS_OUTPUT_FILE}"
  exit "${status}"
fi

exec "${command[@]}"
